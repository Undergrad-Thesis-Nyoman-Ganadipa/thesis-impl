{
  "uid": "driftmon-overview",
  "title": "Embedding Drift — Overview",
  "tags": ["driftmon", "drift"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Status",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Panels stay empty until the drift detector exposes `/metrics` on `10.148.0.7:8000`. The detector (monitoring pipeline) is not deployed yet."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Fréchet Drift Distance (FDD) per window",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 3 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "pointSize": 5, "showPoints": "always" } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "drift_fdd_score",
          "legendFormat": "FDD {{agg}}"
        },
        {
          "refId": "B",
          "expr": "drift_threshold",
          "legendFormat": "threshold"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Detector readiness",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 3 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "detector_readiness == 1",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total windows compared",
      "description": "Windows scored against the baseline since the detector started (counter resets on detector restart).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "drift_windows_processed_total",
          "legendFormat": "windows compared"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Drift events detected (total)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "expr": "drift_detected_total",
          "legendFormat": "drift events"
        }
      ]
    }
  ]
}

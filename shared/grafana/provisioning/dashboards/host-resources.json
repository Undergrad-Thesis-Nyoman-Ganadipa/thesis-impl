{
  "uid": "driftmon-host-resources",
  "title": "Host Resources (per component)",
  "tags": ["driftmon", "node-exporter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "component",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(node_cpu_seconds_total, component)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU used (cores)",
      "description": "rate of non-idle CPU seconds = cores consumed. e2-micro baseline is 0.25 vCPU; sustained values near it mean you are at the burst ceiling.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (component) (rate(node_cpu_seconds_total{component=~\"$component\", mode!=\"idle\"}[1m]))",
          "legendFormat": "{{component}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory used",
      "description": "MemTotal - MemAvailable (working set). e2-micro ceiling is 1 GiB, no swap.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_MemTotal_bytes{component=~\"$component\"} - node_memory_MemAvailable_bytes{component=~\"$component\"}",
          "legendFormat": "{{component}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory used (%)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - node_memory_MemAvailable_bytes{component=~\"$component\"} / node_memory_MemTotal_bytes{component=~\"$component\"})",
          "legendFormat": "{{component}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU steal (throttling evidence)",
      "description": "Want ~0. Non-zero = the host throttled this VM; CPU-demand numbers are not clean while this is positive.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (component) (rate(node_cpu_seconds_total{component=~\"$component\", mode=\"steal\"}[1m]))",
          "legendFormat": "{{component}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Load average (1m)",
      "description": "Saturation check vs the 0.25 vCPU baseline.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "node_load1{component=~\"$component\"}",
          "legendFormat": "{{component}}"
        }
      ]
    }
  ]
}
